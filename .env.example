# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/student_crm

# Security
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this
ENCRYPTION_KEY=your-encryption-key-32-bytes-base64

# Session Configuration
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@studentcrm.com

# AWS S3 for Backup (Optional)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_BACKUP_BUCKET=student-crm-backups
AWS_REGION=ap-southeast-1

# Application
FLASK_ENV=development
FLASK_DEBUG=True
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=./secure_storage
